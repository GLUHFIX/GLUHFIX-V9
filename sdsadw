    if player.Character and player.Character:FindFirstChild("Humanoid") then player.Character.Humanoid.Sit = false end
end)

-- LOOP (REINFORCED)
runService.Heartbeat:Connect(function(dt)
    if not targetPlayer or currentMode == "None" then return end
    
    local char = player.Character
    local tChar = targetPlayer.Character
    
    if char and tChar and char:FindFirstChild("HumanoidRootPart") and tChar:FindFirstChild("HumanoidRootPart") then
        local root = char.HumanoidRootPart
        local hum = char:FindFirstChild("Humanoid")
        local tRoot = tChar.HumanoidRootPart
        local tHead = tChar:FindFirstChild("Head")
        
        stopBar.Visible = true
        for _, v in ipairs(char:GetChildren()) do if v:IsA("BasePart") then v.CanCollide = false end end
        timer = timer + dt * 30
        
        if currentMode == "BACKSHOTS" then
            root.CFrame = tRoot.CFrame * CFrame.new(0, -0.2, 1.2 + math.sin(timer) * 1.5)
        elseif currentMode == "BLOWJOB" and tHead then
            root.CFrame = tHead.CFrame * CFrame.new(0, 0.9, -1.0 + -math.sin(timer) * 1) * CFrame.Angles(0, math.rad(180), 0)
        elseif currentMode == "MY BLOWJOB" then
            root.CFrame = tRoot.CFrame * CFrame.new(0, -2.0, -1.1 + math.sin(timer) * 1) * CFrame.Angles(0, math.rad(180), 0)
        elseif currentMode == "SIT ON HEAD" and tHead then
            if hum then hum.Sit = true end
            root.CFrame = tHead.CFrame * CFrame.new(0, 2.2, 0)
        elseif currentMode == "STICK" then
            root.CFrame = tRoot.CFrame * CFrame.new(0, 0, stickDistance)
        end
    end
end)

local function createModeBtn(name)
    local b = Instance.new("TextButton", optFrame)
    b.Size = UDim2.new(1, 0, 0, 40); b.Text = name; b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    b.TextColor3 = Color3.new(1, 1, 1); b.Font = Enum.Font.GothamBold; b.TextSize = 14
    b.MouseButton1Click:Connect(function() currentMode = name; sliderFrame.Visible = (name == "STICK") end)
    Instance.new("UICorner", b); Instance.new("UIStroke", b).Color = Color3.fromRGB(255, 0, 255)
end

createModeBtn("BACKSHOTS"); createModeBtn("BLOWJOB"); createModeBtn("MY BLOWJOB"); createModeBtn("SIT ON HEAD"); createModeBtn("STICK")

-- PLAYER LIST WITH @NAME
local function updateList()
    for _, v in ipairs(scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, p in ipairs(game.Players:GetPlayers()) do
        if p ~= player then
            local btn = Instance.new("TextButton", scroll)
            btn.Size = UDim2.new(1, -10, 0, 45); -- Etwas größer für 2 Zeilen
            btn.Text = p.DisplayName .. "\n( @" .. p.Name .. " )"
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); btn.TextColor3 = Color3.new(1, 1, 1)
            btn.Font = Enum.Font.GothamBold; btn.TextSize = 12
            btn.MouseButton1Click:Connect(function() targetPlayer = p end)
            Instance.new("UICorner", btn)
        end
    end
end

task.spawn(function() while task.wait(5) do updateList() end end)
updateList()
